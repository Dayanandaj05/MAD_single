<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Temp Converter"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"/>


    <EditText android:id="@+id/editCelsius" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Enter Celsius" android:inputType="numberDecimal" android:minHeight="48dp" android:layout_marginBottom="16dp"/>
    <Button android:id="@+id/btnConvert" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="CONVERT TO FAHRENHEIT" android:layout_marginBottom="16dp"/>
    <TextView android:id="@+id/txtFahrenheit" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fahrenheit: " android:textSize="22sp" android:textStyle="bold"/>

</LinearLayout>
