<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Contacts Provider"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"/>


    <Button android:id="@+id/btnLoadContacts" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="LOAD 5 CONTACTS" android:layout_marginBottom="16dp"/>
    <TextView android:id="@+id/txtContacts" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="List goes here..." />

</LinearLayout>
